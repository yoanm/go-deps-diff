# Mark some files as generated and hide diff by default (use "git diff -a _FILE_" to consider them as text)
/DOC.md                         -diff linguist-generated=true
/managers/README.md             -diff linguist-generated=true
/managers/composer/README.md    -diff linguist-generated=true
/contract/README.md               -diff linguist-generated=true
/testing/README.md              -diff linguist-generated=true
/summary/README.md              -diff linguist-generated=true
/summary/markdown/README.md     -diff linguist-generated=true

# Ignore all test and documentation for archive
/DOC.md                         export-ignore
/managers/README.md             export-ignore
/managers/composer/README.md    export-ignore
/contract/README.md               export-ignore
/testing/README.md              export-ignore
/summary/README.md              export-ignore
/summary/markdown/README.md     export-ignore
/.github                        export-ignore
/.gitattributes                 export-ignore
/.gitignore                     export-ignore
/.editorconfig                  export-ignore
/codecov.yml                    export-ignore
/.golangci.yml                  export-ignore
/.codacy.yml                    export-ignore
/CODE_OF_CONDUCT.md             export-ignore
/CONTRIBUTING.md                export-ignore
/.tools                         export-ignore
/Makefile                       export-ignore
/**_test.go                     export-ignore
/testing                        export-ignore
